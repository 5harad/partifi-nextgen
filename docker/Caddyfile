# Alternate hostnames → canonical site (requires DNS A records to this server).
partifi.com, www.partifi.com, www.partifi.org {
	redir https://{$SITE_ADDRESS:partifi.org}{uri} permanent
}

{$SITE_ADDRESS:partifi.org} {
	encode gzip

	handle /api/* {
		reverse_proxy api:8000
	}

	handle /health* {
		reverse_proxy api:8000
	}

	# Vite build output — content-hashed filenames are safe to cache forever.
	handle /assets/* {
		root * /srv
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Stable public artwork can be reused across pages and sessions.
	handle /images/* {
		root * /srv
		header Cache-Control "public, max-age=86400"
		file_server
	}

	handle {
		root * /srv
		try_files {path} /index.html
		header Cache-Control "no-cache"
		header Cross-Origin-Opener-Policy "same-origin-allow-popups"
		file_server
	}
}
