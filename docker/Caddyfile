# Alternate hostnames → canonical site (requires DNS A records to this server).
partifi.com, www.partifi.com, www.partifi.org {
	redir https://{$SITE_ADDRESS:partifi.org}{uri} permanent
}

{$SITE_ADDRESS:partifi.org} {
	encode gzip

	handle /api/* {
		reverse_proxy api:8000
	}

	handle /health* {
		reverse_proxy api:8000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
