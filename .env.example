# App
APP_ENV=development
APP_SECRET=change-me-to-a-long-random-string
CORS_ORIGINS=http://localhost:5173

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=partifi
MYSQL_USER=partifi
MYSQL_PASSWORD=partifi_dev_password
MYSQL_ROOT_PASSWORD=root_dev_password

# Redis (job queue)
REDIS_URL=redis://redis:6379/0

# S3 (MinIO locally; cdn.partifi.org in production)
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=cdn.partifi.org
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false

# Workers
WORKER_CONCURRENCY=1
# Part generation pool size within a worker (0 = half of CPU cores)
PARTGEN_POOL_SIZE=0
