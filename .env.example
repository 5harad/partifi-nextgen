# App
APP_ENV=development
APP_SECRET=change-me-to-a-long-random-string
CORS_ORIGINS=http://localhost:5173

# Google OAuth (Web client — same client id as VITE_GOOGLE_CLIENT_ID in frontend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=partifi
MYSQL_USER=partifi
MYSQL_PASSWORD=partifi_dev_password
MYSQL_ROOT_PASSWORD=root_dev_password

# Redis (job queue)
REDIS_URL=redis://redis:6379/0

# S3 (MinIO locally; cdn.partifi.org in production)
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=cdn.partifi.org
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
# Browser-reachable MinIO URL for presigned links (docker compose sets this for api)
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000

# Score PDF upload / IMSLP import size limit (MB)
PARTIFI_MAX_SCORE_MB=250

# Workers
JOB_TIMEOUT_SECONDS=2700
# Part generation pool size within a worker (0 = half of CPU cores)
PARTGEN_POOL_SIZE=0

# Local read-through cache (shared Docker volume partifi_cache)
PARTIFI_CACHE_ROOT=/data/partifi
PARTIFI_CACHE_MAX_GB=25
PARTIFI_CACHE_PREVIEW_TTL_DAYS=7
PARTIFI_CACHE_PARTS_TTL_DAYS=7
PARTIFI_CACHE_SCORE_TTL_DAYS=7
PARTIFI_CACHE_SCRATCH_MAX_AGE_HOURS=24
