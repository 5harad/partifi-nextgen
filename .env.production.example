# Production — copy to .env on the EC2 host. Do not commit real values.

APP_ENV=production
APP_SECRET=generate-a-long-random-string
CORS_ORIGINS=https://partifi.org

# Google OAuth (Web client — same value as VITE_GOOGLE_CLIENT_ID below)
GOOGLE_CLIENT_ID=

# Public site hostname (Caddy TLS + routing; partifi.com redirects here via Caddyfile)
SITE_ADDRESS=partifi.org

# Frontend build arg (baked into static bundle at docker build time)
VITE_GOOGLE_CLIENT_ID=

# MySQL (Docker internal — passwords must be strong)
MYSQL_DATABASE=partifi
MYSQL_USER=partifi
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Redis (Docker internal)
REDIS_URL=redis://redis:6379/0

# AWS S3 — existing corpus bucket (leave S3_ENDPOINT_URL unset for real AWS)
S3_BUCKET=cdn.partifi.org
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_USE_SSL=true
# Optional: custom host for browser-facing presigned URLs (if using a CDN CNAME)
# S3_PUBLIC_ENDPOINT_URL=

# Workers (see docs/DEPLOY.md — Memory and workers)
JOB_TIMEOUT_SECONDS=2700
# 0 = auto (half of CPU cores per job subprocess). Lower to 1 if many concurrent heavy imports.
PARTGEN_POOL_SIZE=0

# Local read-through cache (shared volume in docker-compose.prod.yml)
PARTIFI_CACHE_ROOT=/data/partifi
PARTIFI_CACHE_MAX_GB=25
PARTIFI_CACHE_PREVIEW_TTL_DAYS=7
PARTIFI_CACHE_PARTS_TTL_DAYS=7
PARTIFI_CACHE_SCORE_TTL_DAYS=7
PARTIFI_CACHE_SCRATCH_MAX_AGE_HOURS=24
